# ============================================================
# EA1NK-Docker-DXSpider - Example configuration file
# Copy this file as .env and fill in your details before
# starting the stack for the first time.
#   cp .env.example .env
# ============================================================

# --- Cluster node callsign ---
# By convention the suffix -8 is appended to the personal callsign
CLUSTER_CALLSIGN=MYCALL-8

# --- DXSpider branch to use ---
# Options: mojo (recommended) | master
CLUSTER_DXSPIDER_BRANCH=mojo

# --- Sysop details ---
CLUSTER_SYSOP_NAME=Your Name
CLUSTER_SYSOP_CALLSIGN=MYCALL
CLUSTER_SYSOP_PASSWORD=change_this_password

# --- Spiderweb internal user ---
# Created automatically in DXSpider on startup. No need to edit unless required.
CLUSTER_SPIDERWEB_USER=SPIDERWEBUSER
CLUSTER_SPIDERWEB_PASSWORD=change_this_web_password

# --- QTH location ---
CLUSTER_LATITUDE=40.41650
CLUSTER_LONGITUDE=-3.70357
CLUSTER_LOCATOR=IN80DO
CLUSTER_QTH=Madrid, Spain

# --- Sysop contact details ---
CLUSTER_SYSOP_EMAIL=you@youremail.com
CLUSTER_SYSOP_BBS_ADDRESS=

# --- Network and ports ---
# Public domain name or IP address of the server (shown in telnet banner)
CLUSTER_DX_HOSTNAME=dx.yourdomain.com
# Cluster telnet port (standard: 7300)
CLUSTER_PORT=7300
# Sysop web console port
CLUSTER_SYSOP_PORT=8050

# --- MariaDB database ---
# IMPORTANT: change these passwords before the first startup.
# Once the database has been initialised, passwords cannot be changed here
# without deleting the contents of database_data/
CLUSTER_DB_USER=sysop
CLUSTER_DB_PASS=change_this_db_password
CLUSTER_DB_ROOT_PASSWORD=change_this_root_password
CLUSTER_DB_NAME=spiderdb
# Service name as defined in docker-compose.yml. Do not modify.
CLUSTER_DB_HOSTNAME=spider_database
CLUSTER_DB_PORT=3306
